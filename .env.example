# ═══════════════════════════════════════════════════════════════
# AI CIVILIZATION - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#
# REQUIRED for LLM features (Goal Interpreter + Code Gen):
#   Choose ONE provider below. Set its API key.
#
# OPTIONAL but recommended for FULL functionality:
#   - Security tools: Bandit, Safety (auto-detected)
#   - Formal Verification: Z3 solver (auto-detected)
# ═══════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────
# Choose ONE: "openai" or "anthropic"
LLM_PROVIDER=

# ── OpenAI (GPT-4o) ─────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ── Anthropic (Claude) ───────────────────────────────────────────
# Get key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ── LLM Model (optional) ─────────────────────────────────────────
LLM_MODEL=

# ── Infrastructure ────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_civilization
WS_HOST=0.0.0.0
WS_PORT=8765
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9091
GRPC_HOST=0.0.0.0
GRPC_AGENT_PORT=50051
