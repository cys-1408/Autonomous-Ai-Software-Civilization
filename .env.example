# AI Civilization — Environment Configuration
# Copy this to .env and fill in values

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_civilization

# gRPC
GRPC_HOST=0.0.0.0
GRPC_AGENT_PORT=50051
GRPC_SHARED_SECRET=

# WebSocket
WS_HOST=0.0.0.0
WS_PORT=8765
WS_AUTH_TOKEN=

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_HOST=0.0.0.0
PROMETHEUS_PORT=9091

# General
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false
